# Copy this to .env.local and fill in your values
# Never commit .env.local to git

# --- Strava API ---
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# The URL of your deployed app (no trailing slash)
# For local dev: http://localhost:3000
# For production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Vercel Postgres ---
# These are set automatically when you add a Postgres database in the Vercel dashboard
# For local dev, copy them from Vercel dashboard → Storage → your DB → .env.local
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# --- App Security ---
# Random string used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_string

# Your own Strava athlete ID — gates access to /admin (list of connected accounts).
# Leave unset to disable; visiting /admin while signed in will show your ID to copy here.
ADMIN_ATHLETE_ID=
